{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FermiViewer",
  "version": "0.1.9",
  "identifier": "app.fermiviewer.desktop",
  "build": {
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FermiViewer",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 600,
        "url": "loading.html",
        "backgroundColor": "#16141d"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pquarterman17/fermiviewer/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM0QjNDN0JFODIxNzZDQ0QKUldUTmJCZUN2c2V6eEI0cURXdGpTbk9nWk1uckJEZUk4TXQ2eUlyVVo0RVVUa3U1VnlHNW1tMUMK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
