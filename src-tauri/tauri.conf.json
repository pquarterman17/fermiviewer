{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FermiViewer",
  "version": "0.1.2",
  "identifier": "app.fermiviewer.desktop",
  "build": {
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FermiViewer",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 600,
        "url": "loading.html",
        "backgroundColor": "#16141d"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
